-- ============================
-- LOGIC
-- ============================

local function formatNum(n)
    if n >= 1e6 then return string.format("%.1fM", n / 1e6) end
    if n >= 1e3 then return string.format("%.1fK", n / 1e3) end
    return tostring(n)
end

local function refresh()
    if active then
        statusVal.Text = "active"
        statusVal.TextColor3 = Color3.fromHex("#9ece6a")
        btn.Text = "STOP"
        btn.BackgroundColor3 = Color3.fromHex("#9ece6a")
    else
        statusVal.Text = "idle"
        statusVal.TextColor3 = Color3.fromHex("#f7768e")
        btn.Text = "START"
        btn.BackgroundColor3 = Color3.fromHex("#f7768e")
    end
end

local function click()
    if not clickRemote then return end
    pcall(function()
        clickRemote:FireServer()
    end)
    clicks += 1
    clicksVal.Text = formatNum(clicks)
end

local function toggle()
    active = not active
    refresh()
    if active then
        clicks = 0
        startTick = tick()
    end
end

-- button feedback
local function pulse(obj, prop, val)
    TweenService:Create(obj, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {[prop] = val}):Play()
end

btn.MouseEnter:Connect(function() pulse(btn, "BackgroundColor3", active and Color3.fromHex("#73daca") or Color3.fromHex("#ff9e64")) end)
btn.MouseLeave:Connect(function() pulse(btn, "BackgroundColor3", active and Color3.fromHex("#9ece6a") or Color3.fromHex("#f7768e")) end)
btn.MouseButton1Click:Connect(toggle)

-- keybind picker
local picking = false
keyBtn.MouseButton1Click:Connect(function()
    picking = true
    keyBtn.Text = "..."
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if picking and input.UserInputType == Enum.UserInputType.Keyboard then
        HOTKEY = input.KeyCode
        keyBtn.Text = input.KeyCode.Name
        picking = false
        return
    end

    if input.KeyCode == HOTKEY then
        toggle()
    end
end)

-- main loop
local lastFire = 0
RunService.Heartbeat:Connect(function()
    if not active then return end
    local now = tick()
    if now - lastFire >= CLICK_SPEED then
        click()
        lastFire = now
    end
    local elapsed = now - startTick
    if elapsed > 0 then
        cpsVal.Text = formatNum(math.floor(clicks / elapsed)) .. "/s"
    end
end)

refresh()

-- subtle idle blink on status dot
task.spawn(function()
    while true do
        if not active then
            dot.BackgroundColor3 = Color3.fromHex("#3b4261")
            task.wait(0.8)
            dot.BackgroundColor3 = Color3.fromHex("#7aa2f7")
            task.wait(0.8)
        else
            dot.BackgroundColor3 = Color3.fromHex("#9ece6a")
            task.wait(1)
        end
    end
end)

print("clicker loaded — P to toggle")
