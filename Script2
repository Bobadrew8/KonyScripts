--// Hover Effects
local function addHoverEffect(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = hoverColor}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = normalColor}):Play()
    end)
end

addHoverEffect(CloseBtn, Color3.fromRGB(255, 60, 60), Color3.fromRGB(255, 80, 80))
addHoverEffect(MinBtn, Color3.fromRGB(255, 180, 40), Color3.fromRGB(255, 200, 60))

--// Create Item Button
local function createItemButton(item, index)
    local ItemFrame = Instance.new("TextButton")
    ItemFrame.Name = "Item_" .. item.Name
    ItemFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    ItemFrame.Size = UDim2.new(0, 95, 0, 95)
    ItemFrame.Text = ""
    ItemFrame.AutoButtonColor = false
    ItemFrame.LayoutOrder = index
    ItemFrame.Parent = ScrollFrame

    local ItemCorner = Instance.new("UICorner")
    ItemCorner.CornerRadius = UDim.new(0, 8)
    ItemCorner.Parent = ItemFrame

    --// Viewport Frame
    local View = Instance.new("ViewportFrame")
    View.Name = "View"
    View.Size = UDim2.new(1, -10, 1, -30)
    View.Position = UDim2.new(0, 5, 0, 5)
    View.BackgroundTransparency = 1
    View.BorderSizePixel = 0
    View.Parent = ItemFrame

    --// Item Name Label
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Name = "NameLabel"
    NameLabel.BackgroundTransparency = 1
    NameLabel.Position = UDim2.new(0, 5, 1, -25)
    NameLabel.Size = UDim2.new(1, -10, 0, 20)
    NameLabel.Font = Enum.Font.GothamBold
    NameLabel.Text = item.Name
    NameLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
    NameLabel.TextSize = 10
    NameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    NameLabel.Parent = ItemFrame

    --// Create Viewport
    local success, err = pcall(function()
        local viewportclone = item:Clone()
        viewportclone.Parent = View

        local cam = Instance.new("Camera", viewportclone)
        cam.CameraType = Enum.CameraType.Fixed

        local objectPosition = item:IsA("BasePart") and item.Position or Vector3.new(0, 0, 0)
        local cameraPosition = objectPosition + Vector3.new(2, 2, 2)
        cam.CoordinateFrame = CFrame.new(cameraPosition, objectPosition)
        View.CurrentCamera = cam
    end)

    if not success then
        NameLabel.Text = item.Name .. " (err)"
    end

    --// Click Teleport
    ItemFrame.MouseButton1Click:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        if item and item:FindFirstChild("ClickDetector") then
            local savedCFrame = hrp.CFrame

            hrp.CFrame = item.CFrame
            task.wait(0.1)

            local fireSuccess, _ = pcall(function()
                fireclickdetector(item.ClickDetector)
            end)

            task.wait(0.3)
            hrp.CFrame = savedCFrame
        end
    end)

    --// Hover Effects
    ItemFrame.MouseEnter:Connect(function()
        TweenService:Create(ItemFrame, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(55, 55, 75)
        }):Play()
    end)

    ItemFrame.MouseLeave:Connect(function()
        TweenService:Create(ItemFrame, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(40, 40, 55)
        }):Play()
    end)

    return ItemFrame
end

--// Scan and Update Items
local function scanItems()
    local descendants = workspace:GetDescendants()
    local items = {}

    for _, v in ipairs(descendants) do
        if v.Name == "ItemPickupScript" and v.Parent and v.Parent:FindFirstChild("ClickDetector") then
            table.insert(items, v.Parent)
        end
    end

    --// Clear old buttons
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    --// Create new buttons
    for i, item in ipairs(items) do
        createItemButton(item, i)
    end

    StatusLabel.Text = #items .. " items found"
end

--// Initial Scan
scanItems()

--// Auto-refresh every 2 seconds
task.spawn(function()
    while PiggyGui and PiggyGui.Parent do
        task.wait(2)
        pcall(scanItems)
    end
end)
